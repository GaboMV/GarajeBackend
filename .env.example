# Base de datos. Necesitas una base de datos PostgreSQL.
# Ejemplo de conexion local:
# DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/garajes_db?schema=public"

DATABASE_URL="postgresql://postgres:123@localhost:5432/postgres?schema=public"
PORT=3000

# Cloudflare R2 (Storage dual)
R2_ACCOUNT_ID="tu_account_id_cloudflare"
R2_ACCESS_KEY_ID="tu_access_key_id"
R2_SECRET_ACCESS_KEY="tu_secret_access_key"

# Bucket para las fotos públicas
R2_BUCKET_PUBLIC="garajes"
R2_PUBLIC_URL="https://pub-tudominio-r2.dev"

# Bucket blindado para el KYC
R2_BUCKET_PRIVATE="garajes-kyc"

# Frontend Integration
# Reemplaza esta URL con el dominio real donde alojes tu frontend (Vercel, Render, etc.)
FRONTEND_URL="https://tu-dominio-frontend.com"

# Firebase Service Account (Ruta al JSON) para Google Auth
# FIREBASE_SERVICE_ACCOUNT_PATH="serviceAccountKey.json"
