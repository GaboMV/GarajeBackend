# Base de datos. Necesitas una base de datos PostgreSQL.
# Ejemplo de conexion local:
# DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/garajes_db?schema=public"

DATABASE_URL=""
PORT=3000

# Supabase Storage (Almacenamiento de Fotos)
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_KEY="tu_anon_key_o_service_role_key"
SUPABASE_BUCKET_NAME="garajes"
